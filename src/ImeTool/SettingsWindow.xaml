                                </Border>
                                <Border Margin="6,0,0,0" Padding="12,9" Background="{DynamicResource SettingsPreviewBackgroundBrush}" CornerRadius="6">
                                    <StackPanel><TextBlock Text="应用与窗口" Style="{StaticResource RowDescriptionStyle}" Margin="0" /><TextBlock x:Name="ImeTargetWindowText" Text="—" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" /></StackPanel>
                                </Border>
                            </UniformGrid>

                            <TextBlock x:Name="ImeClassInfoText"
                                       Grid.Row="2"
                                       Grid.ColumnSpan="2"
                                       Margin="0,10,0,0"
                                       Foreground="#686868"
                                       FontSize="12"
                                       Text="窗口类：— · 控件类：—"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" />

                        <Grid Margin="18,14,18,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="自定义状态码规则" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Grid.Row="1"
                                       Text="使用上方当前数据创建规则；匹配后优先采用指定的中文或英文状态"
                                       Style="{StaticResource RowDescriptionStyle}" />
                            <Grid Grid.Row="2" Margin="0,12,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Button Width="156" Margin="0,0,8,0" Content="当前数据设为中文" Style="{StaticResource InlineActionButtonStyle}" Click="OnCaptureChineseImeRuleClicked" />
                                    <Button Width="156" Margin="0,0,8,0" Content="当前数据设为英文" Style="{StaticResource InlineActionButtonStyle}" Click="OnCaptureEnglishImeRuleClicked" />
                                    <Button Width="88" Content="删除规则" Style="{StaticResource InlineActionButtonStyle}" Click="OnDeleteImeRuleClicked" />
                                </StackPanel>
                                <ListBox x:Name="ImeDetectionRulesList"
                                         Grid.Row="1"
                                         MinHeight="72"
                                         MaxHeight="190"
                                         Margin="0,10,0,0"
                                         BorderThickness="1"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="8,6">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding SignalText}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding DetailText}" Margin="0,3,0,0" Foreground="#686868" FontSize="11" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Padding="8,3" VerticalAlignment="Center" Background="#160F6CBD" CornerRadius="5">
                                                    <TextBlock Text="{Binding ResultText}" Foreground="#0F5FA8" FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="ApplicationRulesSectionTitle" Text="应用规则" Style="{StaticResource SectionTitleStyle}" Visibility="Collapsed" />
                <Border x:Name="ApplicationRulesSectionGroup" Style="{StaticResource SettingsGroupStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Grid MinHeight="132" Margin="16,8,16,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="WindowMultiple20" Style="{StaticResource RowIconStyle}" VerticalAlignment="Top" Margin="0,8,0,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="8,6,0,0">
                                <TextBlock Text="检测已打开窗口" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="列出当前桌面上的可见窗口，并将对应进程快速加入规则"
                                           Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>

                            <Grid Grid.Row="1" Grid.Column="1" Margin="8,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="64" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="DetectedWindowsBox"
                                          Style="{StaticResource InlineComboBoxStyle}"
                                          SelectionChanged="OnDetectedWindowSelectionChanged"
                                          ToolTip="显示进程名和窗口标题">
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem"
                                               BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                            <Setter Property="MaxWidth"
                                                    Value="{Binding ActualWidth, ElementName=DetectedWindowsBox}" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Grid.Column="2"
                                        Content="刷新"
                                        Style="{StaticResource InlineActionButtonStyle}"
                                        Click="OnRefreshWindowsClicked" />
                            </Grid>

                            <Grid Grid.Row="2" Grid.Column="1" Margin="8,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="116" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="128" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="108" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="AddDetectedWindowToExcludedButton"
                                        Content="加入完全排除"
                                        Style="{StaticResource InlineActionButtonStyle}"
                                        IsEnabled="False"
                                        Click="OnAddDetectedWindowToExcludedClicked" />
                                <Button x:Name="AddDetectedWindowToNoRestoreButton"
                                        Grid.Column="2"
                                        Content="加入不恢复状态"
                                        Style="{StaticResource InlineActionButtonStyle}"
                                        IsEnabled="False"
                                        Click="OnAddDetectedWindowToNoRestoreClicked" />
                                <Button x:Name="AddDetectedWindowAdvancedRuleButton"
                                        Grid.Column="4"
                                        Content="高级规则"
                                        Style="{StaticResource InlineActionButtonStyle}"
                                        IsEnabled="False"
                                        Click="OnAddDetectedWindowAdvancedRuleClicked" />
                                <TextBlock x:Name="DetectedWindowHintText"
                                           Grid.Column="5"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="#686868"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid Margin="16,10,16,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="DocumentSettings20" Style="{StaticResource RowIconStyle}" VerticalAlignment="Top" Margin="0,6,0,0" />
                            <Grid Grid.Column="1" Margin="8,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,18,0">
                                    <TextBlock Text="高级规则" Style="{StaticResource RowTitleStyle}" />
                                    <TextBlock Text="按窗口标题、窗口类或控件类精确匹配，并独立设置行为和位置偏移"
                                               Style="{StaticResource RowDescriptionStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Width="72" Content="新建" Style="{StaticResource InlineActionButtonStyle}" Click="OnNewAdvancedApplicationRuleClicked" />
                                    <Button x:Name="EditAdvancedApplicationRuleButton" Width="72" Margin="8,0,0,0"
                                            Content="编辑" Style="{StaticResource InlineActionButtonStyle}" IsEnabled="False" Click="OnEditAdvancedApplicationRuleClicked" />
                                    <Button x:Name="DeleteAdvancedApplicationRuleButton" Width="72" Margin="8,0,0,0"
                                            Content="删除" Style="{StaticResource InlineActionButtonStyle}" IsEnabled="False" Click="OnDeleteAdvancedApplicationRuleClicked" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Grid.Column="1" Margin="8,12,0,0">
                                <ListBox x:Name="AdvancedApplicationRulesBox"
                                         MinHeight="66"
                                         MaxHeight="156"
                                         Background="{DynamicResource SettingsPreviewBackgroundBrush}"
                                         BorderThickness="1"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         SelectionChanged="OnAdvancedApplicationRuleSelectionChanged"
                                         MouseDoubleClick="OnAdvancedApplicationRuleDoubleClicked">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="6,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding MatchText}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding ActionText}" Margin="0,2,0,0" FontSize="11" Foreground="#686868" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Margin="12,0,2,0" VerticalAlignment="Center"
                                                           Text="{Binding OffsetText}" Foreground="#0F6CBD" FontWeight="SemiBold" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border MinHeight="66"
                                        Padding="16,10"
                                        Background="{DynamicResource SettingsPreviewBackgroundBrush}"
                                        BorderBrush="{DynamicResource SettingsDividerBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        IsHitTestVisible="False">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasItems, ElementName=AdvancedApplicationRulesBox}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                                        <TextBlock Text="暂无高级规则" FontWeight="SemiBold" Foreground="#4B4B4B" />
                                        <TextBlock Margin="10,0,0,0" Text="点击右上角“新建”添加精确匹配规则" Foreground="#686868" FontSize="12" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="142" Margin="16,8,16,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="AppsAddInOff24" Style="{StaticResource RowIconStyle}" VerticalAlignment="Top" Margin="0,8,0,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="8,6,0,0">
                                <TextBlock Text="完全排除" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="不显示标记，也不记忆或恢复输入法状态；每行填写一个进程名"
                                           Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <TextBox x:Name="ExcludedProcessNamesBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Height="82"
                                     Margin="8,10,0,0"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     ToolTip="例如：game、mstsc.exe" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="142" Margin="16,8,16,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="ArrowSyncOff20" Style="{StaticResource RowIconStyle}" VerticalAlignment="Top" Margin="0,8,0,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="8,6,0,0">
                                <TextBlock Text="不恢复状态" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="仍显示标记，但不按窗口自动恢复中英文状态；每行一个进程名"
                                           Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <TextBox x:Name="NoRestoreProcessNamesBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Height="82"
                                     Margin="8,10,0,0"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     ToolTip="例如：Code、chrome.exe" />
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="PreviewSectionTitle" Text="预览" Style="{StaticResource SectionTitleStyle}" Visibility="Collapsed" />
                <Border x:Name="PreviewSectionGroup" Style="{StaticResource SettingsGroupStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Grid Height="154" Margin="16,14,16,12">
                            <Border Background="{DynamicResource SettingsPreviewBackgroundBrush}"
                                    BorderBrush="{DynamicResource SettingsCardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="9" />
                            <TextBlock Text="输入框实时预览"
                                       Margin="18,13,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       FontSize="11"
                                       Foreground="#686868" />
                            <Grid Height="54" Margin="18,38,18,0" VerticalAlignment="Top">
                                <TextBox x:Name="PreviewInputBox"
                                         Text="正在输入一段文字"
                                         Height="52"
                                         Padding="14,0"
                                         IsReadOnly="True"
                                         IsTabStop="False"
                                         VerticalContentAlignment="Center" />
                                <Canvas x:Name="PreviewOverlayCanvas"
                                        Height="52"
                                        IsHitTestVisible="False"
                                        ClipToBounds="False">
                                    <Border x:Name="PreviewCaret"
                                            Canvas.Left="150"
                                            Canvas.Top="14"
                                            Width="1.5"
                                            Height="24"
                                            Background="#202020">
                                        <Border.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.18"
                                                                         Duration="0:0:0.55"
                                                                         AutoReverse="True"
                                                                         RepeatBehavior="Forever" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Border.Triggers>
                                    </Border>
                                    <Border x:Name="PreviewMarkerHost" Background="Transparent" />
                                </Canvas>
                            </Grid>
                        </Grid>

                        <TextBlock x:Name="PreviewHintText"
                                   Margin="60,0,16,14"
                                   Foreground="#686868"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        </Grid>
      </DockPanel>
    </Grid>
</ui:FluentWindow>
