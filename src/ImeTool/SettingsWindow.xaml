<ui:FluentWindow x:Class="ImeTool.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ImeTool 设置"
        Icon="/Assets/AppIcon.ico"
        Width="980"
        Height="740"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Acrylic"
        WindowCornerPreference="Round"
        Background="Transparent"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="13">
    <Window.Resources>
        <!-- These brushes are replaced at runtime so cards blend with the selected system backdrop. -->
        <SolidColorBrush x:Key="SettingsCardBackgroundBrush" Color="#BFFFFFFF" />
        <SolidColorBrush x:Key="SettingsCardBorderBrush" Color="#80FFFFFF" />
        <SolidColorBrush x:Key="SettingsDividerBrush" Color="#3D707070" />
        <SolidColorBrush x:Key="SettingsFooterBackgroundBrush" Color="#B8FAFAFA" />
        <SolidColorBrush x:Key="SettingsPreviewBackgroundBrush" Color="#8CFFFFFF" />
        <SolidColorBrush x:Key="SettingsNavigationBackgroundBrush" Color="#48FFFFFF" />

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#202020" />
            <Setter Property="Margin" Value="4,14,4,8" />
        </Style>

        <Style x:Key="SettingsGroupStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SettingsCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SettingsCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="RowTitleStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#202020" />
        </Style>

        <Style x:Key="RowDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#686868" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,3,0,0" />
        </Style>

        <Style x:Key="RowIconStyle" TargetType="ui:SymbolIcon">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="Foreground" Value="#4B4B4B" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="InlineTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="34" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="InlineComboBoxStyle"
               TargetType="ComboBox"
               BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="34" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="InlineActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SettingsNavigationItemStyle" TargetType="ListBoxItem">
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="8,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Border x:Name="NavigationSurface" CornerRadius="6" Background="Transparent" />
                            <Border x:Name="SelectionIndicator"
                                    Width="3" Height="20" CornerRadius="2"
                                    Margin="2,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="#0F6CBD"
                                    Visibility="Collapsed" />
                            <ContentPresenter Margin="14,0,10,0"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavigationSurface" Property="Background" Value="#10000000" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="NavigationSurface" Property="Background" Value="#18005FB8" />
                                <Setter TargetName="SelectionIndicator" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PreviewStateTabStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="54" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Foreground" Value="#424242" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabSurface"
                                Background="Transparent"
                                BorderBrush="{DynamicResource SettingsCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabSurface" Property="Background" Value="#10000000" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabSurface" Property="Background" Value="#0F6CBD" />
                                <Setter TargetName="TabSurface" Property="BorderBrush" Value="#0F6CBD" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
      <DockPanel LastChildFill="True">
        <ui:TitleBar DockPanel.Dock="Top"
                     Title="ImeTool 设置"
                     Height="48"
                     ShowMinimize="False"
                     ShowMaximize="False"
                     ShowClose="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Assets/AppIcon.ico" Width="20" Height="20" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SettingsFooterBackgroundBrush}"
                BorderBrush="{DynamicResource SettingsDividerBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="SaveHintText"
                           Foreground="#0F7B0F"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Width="104"
                            Margin="0,0,8,0"
                            Click="OnResetClicked">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowReset32" FontSize="17" Margin="0,0,7,0" />
                            <TextBlock Text="恢复默认" />
                        </StackPanel>
                    </Button>
                    <Button Width="82"
                            Margin="0,0,8,0"
                            Click="OnCancelClicked">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Dismiss20" FontSize="17" Margin="0,0,7,0" />
                            <TextBlock Text="取消" />
                        </StackPanel>
                    </Button>
                    <ui:Button Width="108"
                               Appearance="Primary"
                               IsDefault="True"
                               Click="OnSaveClicked">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Save28" FontSize="17" Margin="0,0,7,0" />
                            <TextBlock Text="保存设置" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource SettingsNavigationBackgroundBrush}"
                    BorderBrush="{DynamicResource SettingsDividerBrush}"
                    BorderThickness="0,0,1,0">
                <StackPanel Margin="0,10,0,0">
                    <ListBox x:Name="SettingsNavigation"
                             SelectedIndex="0"
                             SelectionChanged="OnSettingsNavigationChanged"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBoxItem Style="{StaticResource SettingsNavigationItemStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Settings32" FontSize="19" Width="24" />
                                <TextBlock Text="常规" Margin="9,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{StaticResource SettingsNavigationItemStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Target24" FontSize="19" Width="24" />
                                <TextBlock Text="标记与显示" Margin="9,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{StaticResource SettingsNavigationItemStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="WindowSettings20" FontSize="19" Width="24" />
                                <TextBlock Text="窗口记忆" Margin="9,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{StaticResource SettingsNavigationItemStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="KeyboardLayoutFloat24" FontSize="19" Width="24" />
                                <TextBlock Text="快捷键" Margin="9,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{StaticResource SettingsNavigationItemStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Info24" FontSize="19" Width="24" />
                                <TextBlock Text="输入法诊断" Margin="9,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{StaticResource SettingsNavigationItemStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="AppsListDetail24" FontSize="19" Width="24" />
                                <TextBlock Text="应用规则" Margin="9,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>
                </StackPanel>
            </Border>

        <ScrollViewer x:Name="SettingsScroll"
                      Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalContentAlignment="Stretch"
                      VerticalContentAlignment="Top">
            <StackPanel Margin="20,8,20,20" HorizontalAlignment="Stretch">
                <TextBlock x:Name="GeneralSectionTitle" Text="常规" Style="{StaticResource SectionTitleStyle}" />
                <Border x:Name="GeneralSectionGroup" Style="{StaticResource SettingsGroupStyle}">
                    <StackPanel>
                        <Grid MinHeight="72" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="CursorHover24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="状态标记" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="在文本光标旁显示当前中英文状态，并按窗口恢复输入法状态"
                                           Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="EnabledBox"
                                             Grid.Column="2"
                                             VerticalAlignment="Center"
                                             Checked="OnPreviewSettingChanged"
                                             Unchecked="OnPreviewSettingChanged" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="WindowInprivate20" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="静默启动" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="启动时不打开设置窗口，仅驻留系统托盘" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="SilentStartBox" Grid.Column="2" VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="WindowArrowUp24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="开机启动" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="登录 Windows 后自动运行 ImeTool" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="StartupBox" Grid.Column="2" VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="ArrowSync24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="自动检查更新" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="启动后通过 GitHub Releases 检查新版本" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="AutoCheckUpdatesBox" Grid.Column="2" VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="216" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="ArrowDownload24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="软件更新" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock x:Name="UpdateStatusText" Text="检查 GitHub Releases 上的最新版本"
                                           Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Width="104"
                                        Margin="0,0,8,0"
                                        Content="历史版本"
                                        Style="{StaticResource InlineActionButtonStyle}"
                                        Click="OnOpenReleaseHistoryClicked" />
                                <Button x:Name="UpdateActionButton"
                                        Width="104"
                                        Content="检查更新"
                                        Style="{StaticResource InlineActionButtonStyle}"
                                        Click="OnUpdateActionClicked" />
                            </StackPanel>
                        </Grid>

                        <Border x:Name="UpdateNotesPanel"
                                Margin="60,0,16,14"
                                Padding="14,12"
                                Background="{DynamicResource SettingsPreviewBackgroundBrush}"
                                BorderBrush="{DynamicResource SettingsCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Visibility="Collapsed">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="UpdateNotesTitleText"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="#202020" />
                                    <Button Grid.Column="1"
                                            Width="128"
                                            Height="32"
                                            Content="在 GitHub 查看"
                                            Click="OnOpenReleasePageClicked" />
                                </Grid>
                                <TextBlock x:Name="UpdateNotesDateText"
                                           Margin="0,3,0,0"
                                           FontSize="11"
                                           Foreground="#686868" />
                                <Border Height="1"
                                        Margin="0,10,0,10"
                                        Background="{DynamicResource SettingsDividerBrush}" />
                                <ScrollViewer MaxHeight="180"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <TextBlock x:Name="UpdateNotesText"
                                               Padding="0,0,8,0"
                                               Foreground="#404040"
                                               LineHeight="21"
                                               TextWrapping="Wrap" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="LayerDiagonalSparkle24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="设置窗口材质" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="选择云母或亚克力系统背景" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ComboBox x:Name="BackdropBox"
                                      Grid.Column="2"
                                      VerticalAlignment="Center"
                                      SelectionChanged="OnBackdropChanged" />
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="MarkerAppearanceSectionTitle" Text="标记外观" Style="{StaticResource SectionTitleStyle}" Visibility="Collapsed" />
                <Border x:Name="MarkerAppearanceSectionGroup" Style="{StaticResource SettingsGroupStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Shapes24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="样式" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="圆点、文字胶囊或自定义图片" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ComboBox x:Name="StyleBox"
                                      Grid.Column="2"
                                      VerticalAlignment="Center"
                                      SelectionChanged="OnPreviewSettingChanged" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Resize24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="大小" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="6–96 像素" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <TextBox x:Name="SizeBox"
                                     Grid.Column="2"
                                     VerticalAlignment="Center"
                                     TextChanged="OnPreviewSettingChanged" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="ArrowMove24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="位置偏移" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="相对文本光标右下角" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="X" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#686868" />
                                <TextBox x:Name="OffsetXBox" Grid.Column="1" TextChanged="OnPreviewSettingChanged" />
                                <TextBlock Grid.Column="2" Text="Y" VerticalAlignment="Center" Margin="12,0,6,0" Foreground="#686868" />
                                <TextBox x:Name="OffsetYBox" Grid.Column="3" TextChanged="OnPreviewSettingChanged" />
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="DisplayBehaviorSectionTitle" Text="显示行为" Style="{StaticResource SectionTitleStyle}" Visibility="Collapsed" />
                <Border x:Name="DisplayBehaviorSectionGroup" Style="{StaticResource SettingsGroupStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="EyeTracking24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="显示时机" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="常驻显示，或仅在状态变化与输入时短暂显示" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ComboBox x:Name="DisplayModeBox" Grid.Column="2" VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="72" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="DesktopCursor24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="光标捕获模式" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="自动识别环境，也可指定 Win32、UIA、MSAA、浏览器或 JAB"
                                           Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ComboBox x:Name="CaretCaptureModeBox" Grid.Column="2" VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Timer24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="自动隐藏延迟" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="非始终显示模式下的停留时间，300–10000 毫秒" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <TextBox x:Name="AutoHideDelayBox" Grid.Column="2" VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="ArrowSync24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="跟随动画" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="光标移动时让标记平滑跟随" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="MotionBox" Grid.Column="2" VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                            </Grid.ColumnDefinitions>
