<ui:FluentWindow x:Class="ImeTool.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ImeTool 设置"
        Icon="/Assets/AppIcon.ico"
        Width="980"
        Height="740"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Acrylic"
        WindowCornerPreference="Round"
        Background="Transparent"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="13">
    <Window.Resources>
        <!-- These brushes are replaced at runtime so cards blend with the selected system backdrop. -->
        <SolidColorBrush x:Key="SettingsCardBackgroundBrush" Color="#BFFFFFFF" />
        <SolidColorBrush x:Key="SettingsCardBorderBrush" Color="#80FFFFFF" />
        <SolidColorBrush x:Key="SettingsDividerBrush" Color="#3D707070" />
        <SolidColorBrush x:Key="SettingsFooterBackgroundBrush" Color="#B8FAFAFA" />
        <SolidColorBrush x:Key="SettingsPreviewBackgroundBrush" Color="#8CFFFFFF" />
        <SolidColorBrush x:Key="SettingsNavigationBackgroundBrush" Color="#48FFFFFF" />

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#202020" />
            <Setter Property="Margin" Value="4,14,4,8" />
        </Style>

        <Style x:Key="SettingsGroupStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SettingsCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SettingsCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="RowTitleStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#202020" />
        </Style>

        <Style x:Key="RowDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#686868" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,3,0,0" />
        </Style>

        <Style x:Key="RowIconStyle" TargetType="ui:SymbolIcon">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="Foreground" Value="#4B4B4B" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SettingsNavigationItemStyle" TargetType="ListBoxItem">
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="8,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Border x:Name="NavigationSurface" CornerRadius="6" Background="Transparent" />
                            <Border x:Name="SelectionIndicator"
                                    Width="3" Height="20" CornerRadius="2"
                                    Margin="2,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="#0F6CBD"
                                    Visibility="Collapsed" />
                            <ContentPresenter Margin="14,0,10,0"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavigationSurface" Property="Background" Value="#10000000" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="NavigationSurface" Property="Background" Value="#18005FB8" />
                                <Setter TargetName="SelectionIndicator" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PreviewStateTabStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="54" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Foreground" Value="#424242" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabSurface"
                                Background="Transparent"
                                BorderBrush="{DynamicResource SettingsCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabSurface" Property="Background" Value="#10000000" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabSurface" Property="Background" Value="#0F6CBD" />
                                <Setter TargetName="TabSurface" Property="BorderBrush" Value="#0F6CBD" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
      <DockPanel LastChildFill="True">
        <ui:TitleBar DockPanel.Dock="Top"
                     Title="ImeTool 设置"
                     Height="48"
                     ShowMinimize="False"
                     ShowMaximize="False"
                     ShowClose="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Assets/AppIcon.ico" Width="20" Height="20" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SettingsFooterBackgroundBrush}"
                BorderBrush="{DynamicResource SettingsDividerBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="SaveHintText"
                           Foreground="#0F7B0F"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Width="104"
                            Margin="0,0,8,0"
                            Click="OnResetClicked">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowReset32" FontSize="17" Margin="0,0,7,0" />
                            <TextBlock Text="恢复默认" />
                        </StackPanel>
                    </Button>
                    <Button Width="82"
                            Margin="0,0,8,0"
                            Click="OnCancelClicked">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="DismissCircle32" FontSize="17" Margin="0,0,7,0" />
                            <TextBlock Text="取消" />
                        </StackPanel>
                    </Button>
                    <ui:Button Width="108"
                               Appearance="Primary"
                               IsDefault="True"
                               Click="OnSaveClicked">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Save28" FontSize="17" Margin="0,0,7,0" />
                            <TextBlock Text="保存设置" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource SettingsNavigationBackgroundBrush}"
                    BorderBrush="{DynamicResource SettingsDividerBrush}"
                    BorderThickness="0,0,1,0">
                <StackPanel Margin="0,10,0,0">
                    <ListBox x:Name="SettingsNavigation"
                             SelectedIndex="0"
                             SelectionChanged="OnSettingsNavigationChanged"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBoxItem Style="{StaticResource SettingsNavigationItemStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Settings32" FontSize="19" Width="24" />
                                <TextBlock Text="常规" Margin="9,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{StaticResource SettingsNavigationItemStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Target24" FontSize="19" Width="24" />
                                <TextBlock Text="标记与显示" Margin="9,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{StaticResource SettingsNavigationItemStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="WindowSettings20" FontSize="19" Width="24" />
                                <TextBlock Text="窗口记忆" Margin="9,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{StaticResource SettingsNavigationItemStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="KeyboardLayoutFloat24" FontSize="19" Width="24" />
                                <TextBlock Text="快捷键" Margin="9,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{StaticResource SettingsNavigationItemStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="AppsListDetail24" FontSize="19" Width="24" />
                                <TextBlock Text="应用规则" Margin="9,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>
                </StackPanel>
            </Border>

        <ScrollViewer x:Name="SettingsScroll"
                      Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalContentAlignment="Stretch"
                      VerticalContentAlignment="Top">
            <StackPanel Margin="20,8,20,20" HorizontalAlignment="Stretch">
                <TextBlock x:Name="GeneralSectionTitle" Text="常规" Style="{StaticResource SectionTitleStyle}" />
                <Border x:Name="GeneralSectionGroup" Style="{StaticResource SettingsGroupStyle}">
                    <StackPanel>
                        <Grid MinHeight="72" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="CursorHover24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="状态标记" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="在文本光标旁显示当前中英文状态，并按窗口恢复输入法状态"
                                           Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="EnabledBox"
                                             Grid.Column="2"
                                             VerticalAlignment="Center"
                                             Checked="OnPreviewSettingChanged"
                                             Unchecked="OnPreviewSettingChanged" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="WindowInprivate20" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="静默启动" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="启动时不打开设置窗口，仅驻留系统托盘" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="SilentStartBox" Grid.Column="2" VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="WindowArrowUp24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="开机启动" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="登录 Windows 后自动运行 ImeTool" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="StartupBox" Grid.Column="2" VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="ArrowSync24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="自动检查更新" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="启动后通过 GitHub Releases 检查新版本" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="AutoCheckUpdatesBox" Grid.Column="2" VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="ArrowDownload24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="软件更新" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock x:Name="UpdateStatusText" Text="检查 GitHub Releases 上的最新版本"
                                           Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <Button x:Name="UpdateActionButton"
                                    Grid.Column="2"
                                    Content="检查更新"
                                    VerticalAlignment="Center"
                                    Click="OnUpdateActionClicked" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="WindowBrush24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="设置窗口材质" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="选择云母或亚克力系统背景" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ComboBox x:Name="BackdropBox"
                                      Grid.Column="2"
                                      VerticalAlignment="Center"
                                      SelectionChanged="OnBackdropChanged" />
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="MarkerAppearanceSectionTitle" Text="标记外观" Style="{StaticResource SectionTitleStyle}" Visibility="Collapsed" />
                <Border x:Name="MarkerAppearanceSectionGroup" Style="{StaticResource SettingsGroupStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Shapes24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="样式" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="圆点、文字胶囊或自定义图片" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ComboBox x:Name="StyleBox"
                                      Grid.Column="2"
                                      VerticalAlignment="Center"
                                      SelectionChanged="OnPreviewSettingChanged" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Resize24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="大小" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="6–96 像素" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <TextBox x:Name="SizeBox"
                                     Grid.Column="2"
                                     VerticalAlignment="Center"
                                     TextChanged="OnPreviewSettingChanged" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="ArrowMove24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="位置偏移" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="相对文本光标右下角" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="X" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#686868" />
                                <TextBox x:Name="OffsetXBox" Grid.Column="1" TextChanged="OnPreviewSettingChanged" />
                                <TextBlock Grid.Column="2" Text="Y" VerticalAlignment="Center" Margin="12,0,6,0" Foreground="#686868" />
                                <TextBox x:Name="OffsetYBox" Grid.Column="3" TextChanged="OnPreviewSettingChanged" />
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="DisplayBehaviorSectionTitle" Text="显示行为" Style="{StaticResource SectionTitleStyle}" Visibility="Collapsed" />
                <Border x:Name="DisplayBehaviorSectionGroup" Style="{StaticResource SettingsGroupStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="EyeTracking24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="显示时机" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="常驻显示，或仅在状态变化与输入时短暂显示" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ComboBox x:Name="DisplayModeBox" Grid.Column="2" VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Timer24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="自动隐藏延迟" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="非始终显示模式下的停留时间，300–10000 毫秒" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <TextBox x:Name="AutoHideDelayBox" Grid.Column="2" VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="ArrowSync24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="跟随动画" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="光标移动时让标记平滑跟随" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="MotionBox" Grid.Column="2" VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Gauge24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="跟随动画时长" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="40–300 毫秒，数值越小响应越快" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <TextBox x:Name="FollowAnimationDurationBox" Grid.Column="2" VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="CircleHalfFill24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="淡入淡出" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="标记出现和消失时使用轻量过渡" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="FadeAnimationBox" Grid.Column="2" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="WindowMemorySectionTitle" Text="窗口记忆" Style="{StaticResource SectionTitleStyle}" Visibility="Collapsed" />
                <Border x:Name="WindowMemorySectionGroup" Style="{StaticResource SettingsGroupStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Grid MinHeight="76" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="WindowSettings20" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="启用窗口记忆" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="在本次运行期间分别记录每个前台窗口的中英文状态，并在返回窗口时自动恢复；保存后生效"
                                           Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="WindowMemoryEnabledBox"
                                             Grid.Column="2"
                                             VerticalAlignment="Center"
                                             Checked="OnWindowMemoryGlobalChanged"
                                             Unchecked="OnWindowMemoryGlobalChanged" />
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="WindowMemoryListSectionTitle" Text="本次运行的窗口" Style="{StaticResource SectionTitleStyle}" Visibility="Collapsed" />
                <Border x:Name="WindowMemoryListSectionGroup" Style="{StaticResource SettingsGroupStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Grid MinHeight="54" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="WindowMemoryCountText"
                                       VerticalAlignment="Center"
                                       Foreground="#686868"
                                       Text="尚未记录窗口" />
                            <Button Grid.Column="1"
                                    Width="76"
                                    Height="32"
                                    Content="刷新"
                                    Click="OnRefreshWindowMemoryClicked" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" />

                        <Grid x:Name="WindowMemoryListHost">
                            <ItemsControl x:Name="WindowMemoryItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid MinHeight="74" Margin="16,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Symbol="WindowMultiple20" Style="{StaticResource RowIconStyle}" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                                <TextBlock Text="{Binding Title}"
                                                           Style="{StaticResource RowTitleStyle}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding ProcessText}" Foreground="#686868" FontSize="12" />
                                                    <TextBlock Text="  ·  " Foreground="#8A8A8A" FontSize="12" />
                                                    <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusBrush}" FontSize="12" FontWeight="SemiBold" />
                                                    <TextBlock Text="  ·  " Foreground="#8A8A8A" FontSize="12" />
                                                    <TextBlock Text="{Binding LastActiveText}" Foreground="#686868" FontSize="12" />
                                                </StackPanel>
                                            </StackPanel>
                                            <ui:ToggleSwitch Grid.Column="2"
                                                             VerticalAlignment="Center"
                                                             IsChecked="{Binding Enabled, Mode=OneWay}"
                                                             Tag="{Binding Key}"
                                                             Checked="OnWindowMemoryItemToggled"
                                                             Unchecked="OnWindowMemoryItemToggled" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel x:Name="WindowMemoryEmptyState"
                                        Margin="24,30"
                                        HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="WindowMultiple20"
                                               FontSize="30"
                                               Foreground="#777777"
                                               HorizontalAlignment="Center" />
                                <TextBlock Text="尚未记录到窗口"
                                           Margin="0,10,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="#424242"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="切换到需要输入的窗口后，它会出现在这里"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="#686868"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="HotkeysSectionTitle" Text="全局快捷键" Style="{StaticResource SectionTitleStyle}" Visibility="Collapsed" />
                <Border x:Name="HotkeysSectionGroup" Style="{StaticResource SettingsGroupStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Keyboard24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="启用全局快捷键" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="关闭后不注册任何系统级按键" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="GlobalHotkeysBox" Grid.Column="2" VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="300" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Power24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="启用或暂停" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="切换整个工具的启用状态" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="68" />
                                    <ColumnDefinition Width="68" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ToggleEnabledHotkeyBox" IsReadOnly="True" Cursor="Hand" Tag="ToggleEnabled"
                                         PreviewMouseDown="OnHotkeyBoxMouseDown" PreviewKeyDown="OnHotkeyPreviewKeyDown" PreviewKeyUp="OnHotkeyPreviewKeyUp" />
                                <Button Grid.Column="1" Content="录制" Margin="6,0,0,0" Tag="ToggleEnabled" Click="OnRecordHotkeyClicked" />
                                <Button Grid.Column="2" Content="清除" Margin="6,0,0,0" Tag="ToggleEnabled" Click="OnClearHotkeyClicked" />
                            </Grid>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="300" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="EyeOff24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="隐藏或显示标记" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="临时隐藏或重新显示光标标记" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="68" />
                                    <ColumnDefinition Width="68" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ToggleMarkerHotkeyBox" IsReadOnly="True" Cursor="Hand" Tag="ToggleMarkerVisibility"
                                         PreviewMouseDown="OnHotkeyBoxMouseDown" PreviewKeyDown="OnHotkeyPreviewKeyDown" PreviewKeyUp="OnHotkeyPreviewKeyUp" />
                                <Button Grid.Column="1" Content="录制" Margin="6,0,0,0" Tag="ToggleMarkerVisibility" Click="OnRecordHotkeyClicked" />
                                <Button Grid.Column="2" Content="清除" Margin="6,0,0,0" Tag="ToggleMarkerVisibility" Click="OnClearHotkeyClicked" />
                            </Grid>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="300" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="WindowSettings20" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="打开设置" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="从任意应用快速打开此窗口" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="68" />
                                    <ColumnDefinition Width="68" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="OpenSettingsHotkeyBox" IsReadOnly="True" Cursor="Hand" Tag="OpenSettings"
                                         PreviewMouseDown="OnHotkeyBoxMouseDown" PreviewKeyDown="OnHotkeyPreviewKeyDown" PreviewKeyUp="OnHotkeyPreviewKeyUp" />
                                <Button Grid.Column="1" Content="录制" Margin="6,0,0,0" Tag="OpenSettings" Click="OnRecordHotkeyClicked" />
                                <Button Grid.Column="2" Content="清除" Margin="6,0,0,0" Tag="OpenSettings" Click="OnClearHotkeyClicked" />
                            </Grid>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="300" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="DeleteArrowBack20" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="清除当前窗口状态" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="删除当前窗口记忆的中英文状态" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="68" />
                                    <ColumnDefinition Width="68" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ClearWindowStateHotkeyBox" IsReadOnly="True" Cursor="Hand" Tag="ClearCurrentWindowState"
                                         PreviewMouseDown="OnHotkeyBoxMouseDown" PreviewKeyDown="OnHotkeyPreviewKeyDown" PreviewKeyUp="OnHotkeyPreviewKeyUp" />
                                <Button Grid.Column="1" Content="录制" Margin="6,0,0,0" Tag="ClearCurrentWindowState" Click="OnRecordHotkeyClicked" />
                                <Button Grid.Column="2" Content="清除" Margin="6,0,0,0" Tag="ClearCurrentWindowState" Click="OnClearHotkeyClicked" />
                            </Grid>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="56" Margin="16,0">
                            <TextBlock Text="单击“录制”后按下新的组合键；Delete 或 Backspace 可移除绑定。"
                                       VerticalAlignment="Center" Foreground="#686868" FontSize="12" />
                            <Button Content="恢复默认快捷键" HorizontalAlignment="Right" Width="132" Click="OnResetHotkeysClicked" />
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="StateStyleSectionTitle" Text="状态样式" Style="{StaticResource SectionTitleStyle}" Visibility="Collapsed" />
                <Border x:Name="StateStyleSectionGroup" Style="{StaticResource SettingsGroupStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="TextChangeCase24" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="编辑状态" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="切换要修改的中文、英文或大写锁定样式" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <RadioButton x:Name="ChineseStateStyleTab"
                                             Content="中"
                                             Tag="Chinese"
                                             GroupName="StateStyle"
                                             IsChecked="True"
                                             Checked="OnStateStyleChanged"
                                             Style="{StaticResource PreviewStateTabStyle}" />
                                <RadioButton x:Name="EnglishStateStyleTab"
                                             Content="英"
                                             Tag="English"
                                             GroupName="StateStyle"
                                             Checked="OnStateStyleChanged"
                                             Style="{StaticResource PreviewStateTabStyle}" />
                                <RadioButton x:Name="CapsLockStateStyleTab"
                                             Content="A"
                                             Tag="CapsLock"
                                             GroupName="StateStyle"
                                             Checked="OnStateStyleChanged"
                                             Style="{StaticResource PreviewStateTabStyle}" />
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Color16" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="颜色" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock x:Name="StateColorDescription" Text="中文标记颜色" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="38" />
                                    <ColumnDefinition Width="72" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="StateColorBox" TextChanged="OnStateEditorChanged" />
                                <Border x:Name="StateColorSwatch"
                                        Grid.Column="1"
                                        Width="28"
                                        Height="28"
                                        CornerRadius="6"
                                        BorderBrush="#D0D0D0"
                                        BorderThickness="1" />
                                <Button Grid.Column="2" Content="选择" Click="OnPickStateColorClicked" />
                            </Grid>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Text32" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="文字" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock x:Name="StateTextDescription" Text="文字胶囊模式使用" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <TextBox x:Name="StateTextBox" Grid.Column="2" VerticalAlignment="Center" TextChanged="OnStateEditorChanged" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="64" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="300" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Image32" Style="{StaticResource RowIconStyle}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock Text="图片" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock x:Name="StateImageDescription" Text="中文自定义图片" Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="72" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="StateImagePathBox" TextChanged="OnStateEditorChanged" />
                                <Button Grid.Column="1" Content="选择" Margin="8,0,0,0" Click="OnBrowseStateImageClicked" />
                                <Button Grid.Column="2" Content="清空" Margin="8,0,0,0" Click="OnClearStateImageClicked" />
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>
                <TextBlock x:Name="ApplicationRulesSectionTitle" Text="应用规则" Style="{StaticResource SectionTitleStyle}" Visibility="Collapsed" />
                <Border x:Name="ApplicationRulesSectionGroup" Style="{StaticResource SettingsGroupStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Grid MinHeight="132" Margin="16,8,16,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="WindowMultiple20" Style="{StaticResource RowIconStyle}" VerticalAlignment="Top" Margin="0,8,0,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="8,6,0,0">
                                <TextBlock Text="检测已打开窗口" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="列出当前桌面上的可见窗口，并将对应进程快速加入规则"
                                           Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>

                            <Grid Grid.Row="1" Grid.Column="1" Margin="8,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="76" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="DetectedWindowsBox"
                                          Height="34"
                                          DisplayMemberPath="DisplayName"
                                          SelectionChanged="OnDetectedWindowSelectionChanged"
                                          ToolTip="显示进程名和窗口标题" />
                                <Button Grid.Column="1"
                                        Content="刷新"
                                        Margin="8,0,0,0"
                                        Click="OnRefreshWindowsClicked" />
                            </Grid>

                            <Grid Grid.Row="2" Grid.Column="1" Margin="8,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="124" />
                                    <ColumnDefinition Width="136" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="AddDetectedWindowToExcludedButton"
                                        Content="加入完全排除"
                                        IsEnabled="False"
                                        Click="OnAddDetectedWindowToExcludedClicked" />
                                <Button x:Name="AddDetectedWindowToNoRestoreButton"
                                        Grid.Column="1"
                                        Content="加入不恢复状态"
                                        Margin="8,0,0,0"
                                        IsEnabled="False"
                                        Click="OnAddDetectedWindowToNoRestoreClicked" />
                                <TextBlock x:Name="DetectedWindowHintText"
                                           Grid.Column="2"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="#686868"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="142" Margin="16,8,16,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="AppsAddInOff24" Style="{StaticResource RowIconStyle}" VerticalAlignment="Top" Margin="0,8,0,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="8,6,0,0">
                                <TextBlock Text="完全排除" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="不显示标记，也不恢复输入法状态；每行填写一个进程名"
                                           Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <TextBox x:Name="ExcludedProcessNamesBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Height="82"
                                     Margin="8,10,0,0"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     ToolTip="例如：game、mstsc.exe" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SettingsDividerBrush}" Margin="60,0,0,0" />

                        <Grid MinHeight="142" Margin="16,8,16,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="ArrowSyncOff20" Style="{StaticResource RowIconStyle}" VerticalAlignment="Top" Margin="0,8,0,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="8,6,0,0">
                                <TextBlock Text="不恢复状态" Style="{StaticResource RowTitleStyle}" />
                                <TextBlock Text="仍显示标记，但不按窗口自动恢复中英文状态；每行一个进程名"
                                           Style="{StaticResource RowDescriptionStyle}" />
                            </StackPanel>
                            <TextBox x:Name="NoRestoreProcessNamesBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Height="82"
                                     Margin="8,10,0,0"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     ToolTip="例如：Code、chrome.exe" />
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="PreviewSectionTitle" Text="预览" Style="{StaticResource SectionTitleStyle}" Visibility="Collapsed" />
                <Border x:Name="PreviewSectionGroup" Style="{StaticResource SettingsGroupStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Grid Height="154" Margin="16,14,16,12">
                            <Border Background="{DynamicResource SettingsPreviewBackgroundBrush}"
                                    BorderBrush="{DynamicResource SettingsCardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="9" />
                            <TextBlock Text="输入框实时预览"
                                       Margin="18,13,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       FontSize="11"
                                       Foreground="#686868" />
                            <Grid Height="54" Margin="18,38,18,0" VerticalAlignment="Top">
                                <TextBox x:Name="PreviewInputBox"
                                         Text="正在输入一段文字"
                                         Height="52"
                                         Padding="14,0"
                                         IsReadOnly="True"
                                         IsTabStop="False"
                                         VerticalContentAlignment="Center" />
                                <Canvas x:Name="PreviewOverlayCanvas"
                                        Height="52"
                                        IsHitTestVisible="False"
                                        ClipToBounds="False">
                                    <Border x:Name="PreviewCaret"
                                            Canvas.Left="150"
                                            Canvas.Top="14"
                                            Width="1.5"
                                            Height="24"
                                            Background="#202020">
                                        <Border.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.18"
                                                                         Duration="0:0:0.55"
                                                                         AutoReverse="True"
                                                                         RepeatBehavior="Forever" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Border.Triggers>
                                    </Border>
                                    <Border x:Name="PreviewMarkerHost" Background="Transparent" />
                                </Canvas>
                            </Grid>
                        </Grid>

                        <TextBlock x:Name="PreviewHintText"
                                   Margin="60,0,16,14"
                                   Foreground="#686868"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        </Grid>
      </DockPanel>
    </Grid>
</ui:FluentWindow>
