<Window x:Class="ImeTool.Tray.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ImeTool 托盘菜单"
        Width="304"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        WindowStartupLocation="Manual"
        Topmost="True"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="13"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style x:Key="MenuLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#202020" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="MenuDescriptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B6B6B" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>

        <Style x:Key="MenuActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionSurface"
                                Padding="8,0"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionSurface" Property="Background" Value="#EBEBEB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionSurface" Property="Background" Value="#E1E1E1" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ActionSurface" Property="BorderBrush" Value="#0067C0" />
                                <Setter TargetName="ActionSurface" Property="BorderThickness" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="12"
            Padding="8"
            Background="#FAFAFA"
            BorderBrush="#DCDCDC"
            BorderThickness="1"
            CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22"
                              Direction="270"
                              ShadowDepth="4"
                              Color="#55000000"
                              Opacity="0.28" />
        </Border.Effect>

        <StackPanel>
            <Grid Height="52" Margin="6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="34"
                        Height="34"
                        CornerRadius="8"
                        Background="#E8F0FE"
                        VerticalAlignment="Center">
                    <Image Width="24"
                           Height="24"
                           Source="/ImeTool;component/Assets/AppIcon.ico"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock Text="ImeTool" FontSize="14" FontWeight="SemiBold" Foreground="#202020" />
                    <TextBlock x:Name="StatusText" Text="标记已启用" Style="{StaticResource MenuDescriptionStyle}" />
                </StackPanel>
            </Grid>

            <Border Height="1" Background="#E5E5E5" Margin="4,3,4,5" />

            <Grid Height="52" Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Symbol="LocalLanguage24" FontSize="20" Foreground="#505050" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5,0,12,0">
                    <TextBlock Text="状态标记" Style="{StaticResource MenuLabelStyle}" />
                    <TextBlock Text="光标旁中英文提示" Style="{StaticResource MenuDescriptionStyle}" />
                </StackPanel>
                <ui:ToggleSwitch x:Name="EnabledToggle"
                                 Grid.Column="2"
                                 VerticalAlignment="Center"
                                 Checked="OnEnabledToggleChanged"
                                 Unchecked="OnEnabledToggleChanged" />
            </Grid>

            <Grid Height="52" Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Symbol="WindowArrowUp20" FontSize="20" Foreground="#505050" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5,0,12,0">
                    <TextBlock Text="开机启动" Style="{StaticResource MenuLabelStyle}" />
                    <TextBlock Text="登录 Windows 后运行" Style="{StaticResource MenuDescriptionStyle}" />
                </StackPanel>
                <ui:ToggleSwitch x:Name="StartupToggle"
                                 Grid.Column="2"
                                 VerticalAlignment="Center"
                                 Checked="OnStartupToggleChanged"
                                 Unchecked="OnStartupToggleChanged" />
            </Grid>

            <Border Height="1" Background="#E5E5E5" Margin="4,5" />

            <Button Style="{StaticResource MenuActionButtonStyle}"
                    Click="OnSettingsClicked">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon Symbol="Settings32" FontSize="19" Foreground="#505050" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="打开设置" Style="{StaticResource MenuLabelStyle}" Margin="5,0,0,0" />
                    <ui:SymbolIcon Grid.Column="2" Symbol="ChevronRight16" FontSize="14" Foreground="#777777" />
                </Grid>
            </Button>

            <Button Style="{StaticResource MenuActionButtonStyle}"
                    Foreground="#C42B1C"
                    Click="OnExitClicked">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon Symbol="Power24" FontSize="19" Foreground="#C42B1C" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="退出 ImeTool"
                               Foreground="#C42B1C"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="5,0,0,0" />
                </Grid>
            </Button>
        </StackPanel>
    </Border>
</Window>
