<ui:FluentWindow x:Class="ImeTool.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ImeTool 运行日志"
        Icon="/Assets/AppIcon.ico"
        Width="780"
        Height="590"
        MinWidth="620"
        MinHeight="440"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Acrylic"
        WindowCornerPreference="Round"
        Background="Transparent"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="LogCardBrush" Color="#AFFFFFFF" />
        <SolidColorBrush x:Key="LogCardBorderBrush" Color="#70FFFFFF" />
        <SolidColorBrush x:Key="LogFooterBrush" Color="#A8FAFAFA" />
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <ui:TitleBar DockPanel.Dock="Top"
                     Title="运行日志"
                     Height="48"
                     ShowMinimize="False"
                     ShowMaximize="True"
                     ShowClose="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Assets/AppIcon.ico" Width="20" Height="20" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Border DockPanel.Dock="Bottom"
                Padding="20,12"
                Background="{DynamicResource LogFooterBrush}"
                BorderBrush="#30707070"
                BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock x:Name="ActionStatusText"
                           VerticalAlignment="Center"
                           Foreground="#686868" />
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button x:Name="CopyButton"
                            Width="88"
                            Height="34"
                            Margin="0,0,8,0"
                            Content="复制"
                            Click="OnCopyClicked" />
                    <Button x:Name="ExportButton"
                            Width="88"
                            Height="34"
                            Margin="0,0,8,0"
                            Content="导出"
                            Click="OnExportClicked" />
                    <Button Width="88"
                            Height="34"
                            Content="关闭"
                            IsDefault="True"
                            Click="OnCloseClicked" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="18,12,18,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="16,12"
                    Background="{DynamicResource LogCardBrush}"
                    BorderBrush="{DynamicResource LogCardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="捕获等级：" Foreground="#686868" />
                            <TextBlock x:Name="CaptureLevelText" FontWeight="SemiBold" Foreground="#202020" />
                            <TextBlock Margin="16,0,0,0" Text="文件：" Foreground="#686868" />
                            <TextBlock x:Name="LogPathText"
                                       MaxWidth="450"
                                       Foreground="#404040"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <TextBlock x:Name="LogSummaryText"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="#686868" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Width="88"
                            Height="34"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center"
                            Content="刷新"
                            Click="OnRefreshClicked" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Padding="1"
                    Background="{DynamicResource LogCardBrush}"
                    BorderBrush="{DynamicResource LogCardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9">
                <TextBox x:Name="LogTextBox"
                         Padding="14,12"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         Background="#CCFFFFFF"
                         Foreground="#252525"
                         FontFamily="Cascadia Mono, Consolas"
                         FontSize="12.5" />
            </Border>
        </Grid>
    </DockPanel>
</ui:FluentWindow>
