<ui:FluentWindow x:Class="ImeTool.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ImeTool"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="选择颜色"
        Icon="/Assets/AppIcon.ico"
        Width="520"
        Height="690"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        Background="Transparent"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="13">
    <Grid x:Name="AnimatedRoot"
          Opacity="0"
          RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="AnimatedScale" ScaleX="0.965" ScaleY="0.965" />
                <TranslateTransform x:Name="AnimatedTranslate" Y="10" />
            </TransformGroup>
        </Grid.RenderTransform>

        <local:ColorPickerPanel x:Name="Picker" />
    </Grid>
</ui:FluentWindow>
