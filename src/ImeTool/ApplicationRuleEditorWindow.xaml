<ui:FluentWindow x:Class="ImeTool.ApplicationRuleEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="高级应用规则"
        Icon="/Assets/AppIcon.ico"
        Width="560"
        Height="720"
        MinWidth="520"
        MinHeight="620"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Acrylic"
        WindowCornerPreference="Round"
        Background="Transparent"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="EditorCardBrush" Color="#AFFFFFFF" />
        <SolidColorBrush x:Key="EditorBorderBrush" Color="#70FFFFFF" />
        <Style x:Key="EditorLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#303030" />
        </Style>
        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <ui:TitleBar DockPanel.Dock="Top"
                     Title="高级应用规则"
                     Height="48"
                     ShowMinimize="False"
                     ShowMaximize="False"
                     ShowClose="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Assets/AppIcon.ico" Width="20" Height="20" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Border DockPanel.Dock="Bottom" Padding="20,12" Background="#A8FAFAFA" BorderBrush="#30707070" BorderThickness="0,1,0,0">
            <Grid>
                <Button x:Name="DeleteButton" Width="80" Height="34" HorizontalAlignment="Left"
                        Content="删除" Click="OnDeleteClicked" Visibility="Collapsed" />
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Width="80" Height="34" Margin="0,0,8,0" Content="取消" Click="OnCancelClicked" />
                    <Button Width="88" Height="34" Content="保存规则" IsDefault="True" Click="OnSaveClicked" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20,14,20,20">
                <Border Padding="18" Background="{DynamicResource EditorCardBrush}"
                        BorderBrush="{DynamicResource EditorBorderBrush}" BorderThickness="1" CornerRadius="9">
                    <StackPanel>
                        <TextBlock Text="匹配窗口" FontSize="16" FontWeight="SemiBold" Foreground="#202020" />
                        <TextBlock Margin="0,4,0,16" Text="进程名必填，其余条件留空表示匹配该进程的所有窗口。" Foreground="#686868" TextWrapping="Wrap" />

                        <TextBlock Text="进程名" Style="{StaticResource EditorLabelStyle}" />
                        <TextBox x:Name="ProcessNameBox" Style="{StaticResource EditorTextBoxStyle}" ToolTip="例如 chrome 或 chrome.exe" />

                        <TextBlock Margin="0,14,0,5" Text="窗口标题包含" Style="{StaticResource EditorLabelStyle}" />
                        <TextBox x:Name="WindowTitleBox" Style="{StaticResource EditorTextBoxStyle}" />

                        <TextBlock Margin="0,14,0,5" Text="窗口类" Style="{StaticResource EditorLabelStyle}" />
                        <TextBox x:Name="WindowClassBox" Style="{StaticResource EditorTextBoxStyle}" />

                        <TextBlock Margin="0,14,0,5" Text="控件类" Style="{StaticResource EditorLabelStyle}" />
                        <TextBox x:Name="ControlClassBox" Style="{StaticResource EditorTextBoxStyle}" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0" Padding="18" Background="{DynamicResource EditorCardBrush}"
                        BorderBrush="{DynamicResource EditorBorderBrush}" BorderThickness="1" CornerRadius="9">
                    <StackPanel>
                        <TextBlock Text="规则行为" FontSize="16" FontWeight="SemiBold" Foreground="#202020" />
                        <TextBlock Margin="0,4,0,12" Text="各项互相独立，可只调整该应用的气泡位置。" Foreground="#686868" />
                        <CheckBox x:Name="HideMarkerBox" Margin="0,6" Content="隐藏标记" />
                        <CheckBox x:Name="DisableMemoryBox" Margin="0,6" Content="禁用窗口记忆" />
                        <CheckBox x:Name="DisableRestoreBox" Margin="0,6" Content="禁止自动恢复输入法状态" />

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="额外偏移 X" Style="{StaticResource EditorLabelStyle}" />
                                <TextBox x:Name="OffsetXBox" Style="{StaticResource EditorTextBoxStyle}" ToolTip="留空表示不覆盖" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="额外偏移 Y" Style="{StaticResource EditorLabelStyle}" />
                                <TextBox x:Name="OffsetYBox" Style="{StaticResource EditorTextBoxStyle}" ToolTip="留空表示不覆盖" />
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="ValidationText" Margin="0,10,0,0" Foreground="#C42B1C" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</ui:FluentWindow>
