<ui:FluentWindow x:Class="ImeTool.ReleaseHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ImeTool 更新日志"
        Icon="/Assets/AppIcon.ico"
        Width="620"
        Height="560"
        MinWidth="520"
        MinHeight="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Acrylic"
        WindowCornerPreference="Round"
        Background="Transparent"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="HistoryCardBrush" Color="#AFFFFFFF" />
        <SolidColorBrush x:Key="HistoryCardBorderBrush" Color="#70FFFFFF" />
        <SolidColorBrush x:Key="HistoryFooterBrush" Color="#A8FAFAFA" />

        <Style x:Key="HistoryCardStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="Background" Value="{DynamicResource HistoryCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource HistoryCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <ui:TitleBar DockPanel.Dock="Top"
                     Title="ImeTool 更新日志"
                     Height="48"
                     ShowMinimize="False"
                     ShowMaximize="False"
                     ShowClose="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Assets/AppIcon.ico" Width="20" Height="20" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Border DockPanel.Dock="Bottom"
                Padding="20,12"
                Background="{DynamicResource HistoryFooterBrush}"
                BorderBrush="#30707070"
                BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock VerticalAlignment="Center"
                           Foreground="#686868"
                           Text="按版本从新到旧展示" />
                <Button Width="88"
                        Height="34"
                        HorizontalAlignment="Right"
                        Content="关闭"
                        IsDefault="True"
                        Click="OnCloseClicked" />
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Width="548"
                        Margin="0,18,0,14"
                        HorizontalAlignment="Center">
                <TextBlock FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#202020"
                           Text="全部更新日志" />
                <TextBlock Margin="0,5,0,20"
                           FontSize="12"
                           Foreground="#686868"
                           Text="查看 ImeTool 的完整版本更新记录" />

                <ItemsControl x:Name="HistoryItems"
                              HorizontalContentAlignment="Stretch">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border HorizontalAlignment="Stretch"
                                    Style="{StaticResource HistoryCardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Padding="9,4"
                                                Background="#160F6CBD"
                                                CornerRadius="5">
                                            <TextBlock FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="#0F5FA8"
                                                       Text="{Binding VersionLabel}" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="#686868"
                                                   Text="{Binding Date}" />
                                    </Grid>

                                    <Border Height="1"
                                            Margin="0,13,0,12"
                                            Background="#30707070" />

                                    <TextBlock Foreground="#383838"
                                               LineHeight="22"
                                               Text="{Binding Notes}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</ui:FluentWindow>
