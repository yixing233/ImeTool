<UserControl x:Class="ImeTool.ColorPickerPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Focusable="True"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="13">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PickerChromeBrush" Color="#F5F8F8F8" />
        <SolidColorBrush x:Key="PickerSurfaceBrush" Color="#FFF9F9F9" />
        <SolidColorBrush x:Key="PickerBorderBrush" Color="#1A000000" />
        <SolidColorBrush x:Key="PickerFooterBrush" Color="#FFF7F7F7" />

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#686868" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="ChannelBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="MaxLength" Value="3" />
        </Style>

        <Style x:Key="ChromeCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border x:Name="PickerChrome"
                Background="{DynamicResource PickerChromeBrush}"
                BorderBrush="{DynamicResource PickerBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                SizeChanged="OnPanelChromeSizeChanged">
          <DockPanel LastChildFill="True">
            <Grid DockPanel.Dock="Top"
                  Height="52"
                  Margin="16,0,10,0"
                  MouseLeftButtonDown="OnHeaderMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Image Source="/Assets/AppIcon.ico" Width="20" Height="20" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="选择颜色"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold" />
                <Button Grid.Column="2"
                        Style="{StaticResource ChromeCloseButtonStyle}"
                        Width="36"
                        Height="32"
                        Padding="0"
                        ToolTip="关闭"
                        Click="OnCancelClicked">
                    <ui:SymbolIcon Symbol="Dismiss20" FontSize="16" />
                </Button>
            </Grid>

            <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource PickerFooterBrush}"
                BorderBrush="{DynamicResource PickerBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="SelectedHexText"
                           VerticalAlignment="Center"
                           Foreground="#686868"
                           FontFamily="Cascadia Mono, Consolas" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Width="82" Margin="0,0,8,0" Click="OnCancelClicked">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="16" Margin="0,0,7,0" />
                            <TextBlock Text="取消" />
                        </StackPanel>
                    </Button>
                    <ui:Button Width="102" Appearance="Primary" Click="OnConfirmClicked">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Checkmark24" FontSize="16" Margin="0,0,7,0" />
                            <TextBlock Text="使用颜色" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </Grid>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="22,14,22,20">
                <Grid x:Name="SpectrumSurface"
                      Height="250"
                      Cursor="Cross"
                      ClipToBounds="True"
                      SizeChanged="OnPickerSizeChanged"
                      MouseLeftButtonDown="OnSpectrumMouseDown"
                      MouseMove="OnSpectrumMouseMove"
                      MouseLeftButtonUp="OnSpectrumMouseUp">
                    <Border x:Name="SpectrumHue" CornerRadius="10" />
                    <Border CornerRadius="10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="White" Offset="0" />
                                <GradientStop Color="#00FFFFFF" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border CornerRadius="10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Color="#00000000" Offset="0" />
                                <GradientStop Color="Black" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Canvas IsHitTestVisible="False">
                        <Ellipse x:Name="SpectrumThumb"
                                 Width="16"
                                 Height="16"
                                 Fill="Transparent"
                                 Stroke="White"
                                 StrokeThickness="2">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="0" Opacity="0.7" />
                            </Ellipse.Effect>
                        </Ellipse>
                    </Canvas>
                </Grid>

                <TextBlock Text="色相" Style="{StaticResource FieldLabelStyle}" Margin="0,14,0,6" />
                <Grid x:Name="HueSurface"
                      Height="22"
                      Cursor="Hand"
                      ClipToBounds="False"
                      SizeChanged="OnPickerSizeChanged"
                      MouseLeftButtonDown="OnHueMouseDown"
                      MouseMove="OnHueMouseMove"
                      MouseLeftButtonUp="OnHueMouseUp">
                    <Border CornerRadius="7" Margin="0,3">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#FFFF0000" Offset="0" />
                                <GradientStop Color="#FFFFFF00" Offset="0.1667" />
                                <GradientStop Color="#FF00FF00" Offset="0.3333" />
                                <GradientStop Color="#FF00FFFF" Offset="0.5" />
                                <GradientStop Color="#FF0000FF" Offset="0.6667" />
                                <GradientStop Color="#FFFF00FF" Offset="0.8333" />
                                <GradientStop Color="#FFFF0000" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Canvas IsHitTestVisible="False">
                        <Border x:Name="HueThumb"
                                Width="8"
                                Height="22"
                                Background="White"
                                BorderBrush="#77000000"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="0" Opacity="0.45" />
                            </Border.Effect>
                        </Border>
                    </Canvas>
                </Grid>

                <Border Margin="0,16,0,0"
                        Padding="14"
                        Background="{DynamicResource PickerSurfaceBrush}"
                        BorderBrush="{DynamicResource PickerBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="82" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid>
                            <Border x:Name="SelectedColorSwatch" CornerRadius="9" BorderBrush="#33000000" BorderThickness="1" />
                            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="7" Background="#AAFFFFFF" CornerRadius="4" Padding="5,2">
                                <TextBlock Text="预览" FontSize="11" Foreground="#5A5A5A" />
                            </Border>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.25*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.ColumnSpan="5">
                                <TextBlock Text="HEX" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox x:Name="HexBox"
                                         Height="34"
                                         MaxLength="7"
                                         FontFamily="Cascadia Mono, Consolas"
                                         VerticalContentAlignment="Center"
                                         TextChanged="OnHexTextChanged"
                                         LostKeyboardFocus="OnColorFieldLostFocus" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="R" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox x:Name="RedBox" Style="{StaticResource ChannelBoxStyle}" TextChanged="OnRgbTextChanged" LostKeyboardFocus="OnColorFieldLostFocus" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="G" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox x:Name="GreenBox" Style="{StaticResource ChannelBoxStyle}" TextChanged="OnRgbTextChanged" LostKeyboardFocus="OnColorFieldLostFocus" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="4">
                                <TextBlock Text="B" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox x:Name="BlueBox" Style="{StaticResource ChannelBoxStyle}" TextChanged="OnRgbTextChanged" LostKeyboardFocus="OnColorFieldLostFocus" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Text="常用颜色" Style="{StaticResource FieldLabelStyle}" Margin="0,14,0,7" />
                <UniformGrid Rows="1" Columns="10">
                    <Button Tag="#EF4444" ToolTip="#EF4444" Height="38" Click="OnPresetClicked" Margin="0,0,5,0" Padding="0" Background="Transparent" BorderThickness="0"><Border Width="28" Height="28" Background="#EF4444" BorderBrush="#33000000" BorderThickness="1" CornerRadius="14" /></Button>
                    <Button Tag="#F97316" ToolTip="#F97316" Height="38" Click="OnPresetClicked" Margin="0,0,5,0" Padding="0" Background="Transparent" BorderThickness="0"><Border Width="28" Height="28" Background="#F97316" BorderBrush="#33000000" BorderThickness="1" CornerRadius="14" /></Button>
                    <Button Tag="#EAB308" ToolTip="#EAB308" Height="38" Click="OnPresetClicked" Margin="0,0,5,0" Padding="0" Background="Transparent" BorderThickness="0"><Border Width="28" Height="28" Background="#EAB308" BorderBrush="#33000000" BorderThickness="1" CornerRadius="14" /></Button>
                    <Button Tag="#22C55E" ToolTip="#22C55E" Height="38" Click="OnPresetClicked" Margin="0,0,5,0" Padding="0" Background="Transparent" BorderThickness="0"><Border Width="28" Height="28" Background="#22C55E" BorderBrush="#33000000" BorderThickness="1" CornerRadius="14" /></Button>
                    <Button Tag="#14B8A6" ToolTip="#14B8A6" Height="38" Click="OnPresetClicked" Margin="0,0,5,0" Padding="0" Background="Transparent" BorderThickness="0"><Border Width="28" Height="28" Background="#14B8A6" BorderBrush="#33000000" BorderThickness="1" CornerRadius="14" /></Button>
                    <Button Tag="#06B6D4" ToolTip="#06B6D4" Height="38" Click="OnPresetClicked" Margin="0,0,5,0" Padding="0" Background="Transparent" BorderThickness="0"><Border Width="28" Height="28" Background="#06B6D4" BorderBrush="#33000000" BorderThickness="1" CornerRadius="14" /></Button>
                    <Button Tag="#2563EB" ToolTip="#2563EB" Height="38" Click="OnPresetClicked" Margin="0,0,5,0" Padding="0" Background="Transparent" BorderThickness="0"><Border Width="28" Height="28" Background="#2563EB" BorderBrush="#33000000" BorderThickness="1" CornerRadius="14" /></Button>
                    <Button Tag="#8B5CF6" ToolTip="#8B5CF6" Height="38" Click="OnPresetClicked" Margin="0,0,5,0" Padding="0" Background="Transparent" BorderThickness="0"><Border Width="28" Height="28" Background="#8B5CF6" BorderBrush="#33000000" BorderThickness="1" CornerRadius="14" /></Button>
                    <Button Tag="#EC4899" ToolTip="#EC4899" Height="38" Click="OnPresetClicked" Margin="0,0,5,0" Padding="0" Background="Transparent" BorderThickness="0"><Border Width="28" Height="28" Background="#EC4899" BorderBrush="#33000000" BorderThickness="1" CornerRadius="14" /></Button>
                    <Button Tag="#64748B" ToolTip="#64748B" Height="38" Click="OnPresetClicked" Padding="0" Background="Transparent" BorderThickness="0"><Border Width="28" Height="28" Background="#64748B" BorderBrush="#33000000" BorderThickness="1" CornerRadius="14" /></Button>
                </UniformGrid>
            </StackPanel>
            </ScrollViewer>
          </DockPanel>
        </Border>
    </Grid>
</UserControl>
